{
  "name": "omni-monorepo",
  "version": "1.0.0",
  "description": "Omni Integrated Discord Solution Monorepo",
  "private": true,
  "scripts": {
    "dev:bot": "npm run dev --prefix omni-bot",
    "dev:dashboard": "npm run dev --prefix omni-dashboard",
    "dev": "npx concurrently \"npm run dev:bot\" \"npm run dev:dashboard\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^8.2.2",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
